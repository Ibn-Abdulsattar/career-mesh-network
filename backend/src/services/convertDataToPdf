import PDFDocument from "pdfkit";
import fs from "fs";
import crypto from "node:crypto";

const convertDataToPdf = async (userData) => {
  const { user } = userData;
//   const { experiences, educations } = user.profile;
  const doc = new PDFDocument();

  const outputPath = crypto.randomBytes(32).toString("hex") + ".pdf";
  const stream = fs.createWriteStream("../upload" + outputPath);

  doc.pipe(stream);

  doc.image(userData.avatar_url, 100, 100, {
    width: 100,
    align: "center",
  });

  doc.fontSize(25).text(user.username, 100, 100);
//   doc.fontSize(25).text(experiences, 50, 50);
//   doc.fontSize(25).text(educations, 50, 50);

  doc.end();
  return outputPath;
};

export default convertDataToPdf;
